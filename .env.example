# =============================================================================
# AI Tutor — environment variables
# =============================================================================
#
# WHERE TO PASTE YOUR KEY (do this once per machine):
#
#   1. Copy this file and rename the copy to:  .env
#      Full path on your PC should be:
#        E:\AI tutor\.env
#
#   2. Create a key here (API, not ChatGPT login):
#        https://platform.openai.com/api-keys
#
#   3. Paste the full secret on the line below (starts with sk- or sk-proj-).
#      No quotes. No spaces before/after.
#
#   4. Save the file, then restart the server:
#        python -m uvicorn app.main:app --host 127.0.0.1 --port 8000
#
#   5. Open the app and check:
#        http://127.0.0.1:8000/api/health
#      You want: "openai_configured": true, "openai_key_format_ok": true
#
# Never commit .env to git (it is listed in .gitignore).
# =============================================================================

OPENAI_API_KEY=sk-your-key-paste-here

# Chat model for the tutor (must support tools; default is fast and cheap).
TUTOR_MODEL=gpt-4o-mini

# --- Using API credits more safely (optional) ---
# Hard cap on how many tool/model turns one chat can take (1–8). Lower = cheaper.
# TUTOR_MAX_AGENT_ITERATIONS=3
# Cap on how many tokens the model may output per call (256–8192). Lower = cheaper.
# TUTOR_MAX_OUTPUT_TOKENS=1536
#
# Also set spend limits in OpenAI (recommended): Billing → Limits / budget alerts
# https://platform.openai.com/account/billing
#
# Run only ONE server for this app at a time (multiple uvicorn = multiple spend).

# --- Auth (v2) ---
# Required for stable logins across server restarts (use a long random string in production).
# JWT_SECRET=your-long-random-secret-at-least-32-chars
#
# Optional token lifetime (minutes); app clamps to a safe range.
# JWT_EXPIRE_MINUTES=10080

# --- Database ---
# Default: SQLite at data/tutor.db
# For PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/aitutor

# --- Rate limits ---
# Max tutor messages per user per rolling minute (5–120).
# RATE_CHAT_PER_MINUTE=30

# --- Stronger personalization & speed (optional) ---
# Last N chat messages sent to the model (4–32, even number recommended).
# TUTOR_MAX_HISTORY_MESSAGES=16
# Max characters of long-term memory injected before each reply (200–2500).
# TUTOR_PROFILE_MAX_CHARS=900
# LLM request timeout seconds (20–120).
# TUTOR_LLM_TIMEOUT=45
